# ============================================
# CORE APPLICATION CONFIGURATION
# ============================================

# GEMINI_API_KEY: Required for Gemini AI API calls
GEMINI_API_KEY=your-gemini-api-key-here

# APP_URL: The URL where this application is hosted
APP_URL=http://localhost:5000

# JWT_SECRET: Secret key for signing JSON Web Tokens
JWT_SECRET=change-this-to-secure-key-in-production

# Application Settings
VITE_APP_NAME=EFTAXAE - UAE VAT Filing System
NODE_ENV=development
VITE_LOG_LEVEL=info

# ============================================
# PAYMENT GATEWAY CONFIGURATION
# ============================================

# Global Payment Settings
VITE_PAYMENT_DEBUG=true
VITE_WEBHOOK_SECRET=webhook-secret-key-here

# Stripe Integration (Optional)
VITE_STRIPE_ENABLED=false
VITE_STRIPE_PUBLIC_KEY=pk_test_your_test_key_here

# PayPal Integration (Optional)
VITE_PAYPAL_ENABLED=false
VITE_PAYPAL_CLIENT_ID=your-paypal-client-id

# 2Checkout Integration (Optional)
VITE_2CHECKOUT_ENABLED=false
VITE_2CHECKOUT_MERCHANT_CODE=your-merchant-code

# Emirates NBD Integration (Optional)
VITE_ENBD_ENABLED=false
VITE_ENBD_MERCHANT_ID=your-enbd-merchant-id

# FABD Integration (Optional)
VITE_FABD_ENABLED=false
VITE_FABD_MERCHANT_ID=your-fabd-merchant-id

# ============================================
# OTP & COMMUNICATION SERVICES
# ============================================

# OTP Provider: mock (dev), twilio (production)
VITE_OTP_PROVIDER=mock

# Twilio Configuration (for production OTP delivery)
# VITE_TWILIO_ACCOUNT_SID=your-account-sid
# VITE_TWILIO_AUTH_TOKEN=your-auth-token
# VITE_TWILIO_FROM_NUMBER=+971XXXXXXXXX

# Email Service Provider: mock (dev), sendgrid (production)
VITE_EMAIL_PROVIDER=mock

# SendGrid Configuration (for production email)
# VITE_SENDGRID_API_KEY=SG.your-sendgrid-api-key

# ============================================
# AWS SERVICES (Optional)
# ============================================

# VITE_AWS_REGION=me-south-1
# VITE_AWS_ACCESS_KEY_ID=your-access-key
# VITE_AWS_SECRET_ACCESS_KEY=your-secret-key
# VITE_AWS_SES_EMAIL=noreply@payaetax.online

# ============================================
# ALTERNATIVE PAYMENT METHODS
# ============================================

# Mobile Wallet (Apple Pay, Google Pay)
VITE_MOBILE_WALLET_ENABLED=false

# Bank Transfer
VITE_BANK_TRANSFER_ENABLED=false
VITE_FTA_ACCOUNT_NUMBER=123456789

# Installment Plans (Tamara, Tabby)
VITE_INSTALLMENTS_ENABLED=false

# ============================================
# SECURITY SETTINGS
# ============================================

VITE_REQUIRE_SSL=true
VITE_CERT_PINNING_ENABLED=false

# ============================================
# VITE CONFIGURATION
# ============================================

DISABLE_HMR=false
